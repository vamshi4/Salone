generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  email     String?  @unique
  name      String?
  role      UserRole @default(CUSTOMER)
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  lat       Float?
  lng       Float?

  // Forgot-password OTP (sent via WhatsApp). Hash format matches `password`
  // (scrypt$salt$hash, see src/password.ts) so the same verify helper works
  // for both. Cleared after a successful reset or on expiry.
  resetOtpHash      String?
  resetOtpExpiresAt DateTime?
  resetOtpAttempts  Int       @default(0)
  resetOtpSentAt    DateTime?

  // Google's stable per-account "sub" claim, set the first time someone
  // signs in or links via "Continue with Google" (free — no per-message
  // cost like the WhatsApp OTP above, so this is the escape hatch for
  // owners who don't want to depend on a paid channel to recover access).
  googleId String? @unique

  stylist       Stylist?
  salonOwned    Salon[]       @relation("SalonOwner")
  bookings      Booking[]     @relation("CustomerBookings")
  salonCustomers SalonCustomer[]
}

model Stylist {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  registrationType          RegistrationType @default(INDEPENDENT)
  primarySalonId            String?
  independentBookingEnabled Boolean  @default(true)
  basePrice                 Int?
  homeServiceEnabled        Boolean  @default(false)
  homeServiceCatalog        Json?
  reviewFlagsUsed           Int      @default(0)
  reviewFlagsResetAt        DateTime @default(now())
  lat                       Float?
  lng                       Float?
  rating                    Float    @default(0)
  totalReviews              Int      @default(0)
  deletedAt                 DateTime?

  user          User            @relation(fields: [userId], references: [id])
  primarySalon  Salon?          @relation("PrimaryStylists", fields: [primarySalonId], references: [id])
  salonStylists SalonStylist[]
  bookings      Booking[]
  services      Service[]
  availability  StylistAvailability[]
  payouts       StylistPayout[]
}

model StylistAvailability {
  id          String   @id @default(cuid())
  stylistId   String
  dayOfWeek   Int?
  date        DateTime?
  startTime   String
  endTime     String
  isBlocked   Boolean  @default(false)
  createdAt   DateTime @default(now())

  stylist Stylist @relation(fields: [stylistId], references: [id])

  @@index([stylistId, date])
  @@index([stylistId, dayOfWeek])
}

model Salon {
  id              String   @id @default(cuid())
  ownerId         String   // no longer @unique — an owner can have multiple branches
  name            String
  address         String
  lat             Float
  lng             Float
  noShowPenalty   Int      @default(0)
  noShowSplit     Json     @default("{\"stylist\": 70, \"salon\": 30}")
  commissionRate  Int      @default(0)
  saasPlan        String   @default("FREE")
  rating          Float    @default(0)
  totalReviews    Int      @default(0)
  currency        String   @default("INR")
  countryCode     String   @default("IN")
  dailyRevenueGoal Int?
  deletedAt       DateTime?

  owner             User            @relation("SalonOwner", fields: [ownerId], references: [id])
  stylists          SalonStylist[]
  stylistsPrimary   Stylist[]       @relation("PrimaryStylists")
  bookings          Booking[]
  services          Service[]
  customers         SalonCustomer[]
  stylistPayouts    StylistPayout[]
  products          Product[]

  @@index([ownerId])
}

model SalonCustomer {
  id         String   @id @default(cuid())
  salonId    String
  customerId String
  notes      String   @default("")
  tags       Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  salon    Salon @relation(fields: [salonId], references: [id])
  customer User  @relation(fields: [customerId], references: [id])

  @@unique([salonId, customerId])
  @@index([customerId])
}

model SalonStylist {
  id              String             @id @default(cuid())
  salonId         String
  stylistId       String
  status          SalonStylistStatus @default(PENDING)
  exclusive       Boolean            @default(false)
  canSetOwnPrice  Boolean            @default(false)
  canCancelBooking Boolean           @default(false)
  priceOverrides  Json?
  commissionRate  Int                @default(70)
  payType         StaffPayType       @default(COMMISSION)
  salaryAmount    Int                @default(0) // monthly, in paise/cents — only meaningful for SALARY/BOTH
  joinedAt        DateTime           @default(now())

  salon   Salon   @relation(fields: [salonId], references: [id])
  stylist Stylist @relation(fields: [stylistId], references: [id])

  @@unique([salonId, stylistId])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  category    String
  duration    Int
  salonId     String?
  stylistId   String?
  basePrice   Int

  salon   Salon?   @relation(fields: [salonId], references: [id])
  stylist Stylist? @relation(fields: [stylistId], references: [id])
  bookings Booking[]
  bookingItems BookingServiceItem[]
}

// Retail inventory — deliberately minimal v1 (mirrors Service's flat shape):
// no supplier/cost tracking, no stock-movement ledger, no variants. stockQty
// is a plain mutable count, not derived from a transaction history, same
// tradeoff Service.basePrice already makes. Soft-delete (unlike Service's
// hard delete) since stock/sales history will reference products later.
model Product {
  id                String    @id @default(cuid())
  salonId           String
  name              String
  category          String
  sku               String?
  retailPrice       Int
  stockQty          Int       @default(0)
  lowStockThreshold Int       @default(5)
  deletedAt         DateTime?

  salon Salon @relation(fields: [salonId], references: [id])

  @@index([salonId])
}

model Booking {
  id                  String        @id @default(cuid())
  customerId          String
  providerType        ProviderType
  salonId             String?
  stylistId           String?
  serviceId           String
  bookedVia           BookedVia
  serviceType         ServiceType   @default(IN_SALON)
  slotStart           DateTime
  slotEnd             DateTime
  originalDateTime    DateTime?
  proposedDateTime    DateTime?
  rescheduleReason    String?
  rescheduleProposedBy String?
  price               Int
  travelFee           Int           @default(0)
  platformFee         Int
  stylistPayout       Int
  salonPayout         Int
  commissionSnapshot  Json
  status              BookingStatus @default(PENDING)
  paymentId           String?
  paymentMethod       PaymentMethod?
  noShowCharged       Boolean       @default(false)
  createdAt           DateTime      @default(now())
  completedAt         DateTime?     // set when a service is logged as done; drives earnings
  payoutId            String?       // set once this booking's stylistPayout has been settled

  customer  User      @relation("CustomerBookings", fields: [customerId], references: [id])
  salon     Salon?    @relation(fields: [salonId], references: [id])
  stylist   Stylist?  @relation(fields: [stylistId], references: [id])
  service   Service   @relation(fields: [serviceId], references: [id])
  services  BookingServiceItem[]
  review    Review?
  payout    StylistPayout? @relation(fields: [payoutId], references: [id])

  @@index([stylistId, slotStart])
  @@index([salonId, status])
  @@index([payoutId])
}

// A settled batch of commission payouts to one stylist at one salon for a
// date range — created by summing that stylist's COMPLETED, not-yet-paid
// bookings (Booking.payoutId == null) in the range. Bookings are linked via
// the Booking.payoutId FK (not a Json snapshot) so "what's still unpaid" is
// a trivial payoutId: null filter, and "what did this payout cover" is
// queryable from either side.
model StylistPayout {
  id           String   @id @default(cuid())
  salonId      String
  stylistId    String
  periodStart  DateTime
  periodEnd    DateTime
  grossRevenue Int
  totalPayout  Int
  bookingCount Int
  paidAt       DateTime @default(now())
  paidBy       String
  note         String?
  createdAt    DateTime @default(now())
  // A fixed-salary settlement (as opposed to a commission-on-bookings
  // settlement) — no bookings are linked, grossRevenue/bookingCount stay 0.
  // salaryMonth ("YYYY-MM") makes "already paid this month" a trivial
  // lookup instead of parsing periodStart/periodEnd.
  isSalaryPayout Boolean @default(false)
  salaryMonth    String?

  salon    Salon     @relation(fields: [salonId], references: [id])
  stylist  Stylist   @relation(fields: [stylistId], references: [id])
  bookings Booking[]

  @@index([salonId, stylistId])
  @@index([stylistId, periodStart])
  @@index([stylistId, salaryMonth])
}

model BookingServiceItem {
  id        String   @id @default(cuid())
  bookingId String
  serviceId String
  sortOrder Int      @default(0)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([bookingId, serviceId])
  @@index([serviceId])
}

model Review {
  id               String           @id @default(cuid())
  bookingId        String           @unique
  customerId       String
  stylistRating    Int?
  salonRating      Int?
  stylistComment   String?
  salonComment     String?
  reviewTargetType ReviewTargetType @default(BOTH)
  flaggedToSalon   Boolean          @default(false)
  flagReason       String?
  createdAt        DateTime         @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String            // the SUPER_ADMIN user id
  action     String            // "salon.update" | "salon.delete" | "user.reset-password" | ...
  targetType String            // "Salon" | "User" | "Booking" | "SalonCustomer" | ...
  targetId   String
  before     Json?             // snapshot before the change (omit secrets like password hash)
  after      Json?             // snapshot after
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([actorId])
}

enum UserRole {
  CUSTOMER
  STYLIST
  SALON_OWNER
  SUPER_ADMIN
}

enum RegistrationType {
  INDEPENDENT
  SALON_EXCLUSIVE
}

enum SalonStylistStatus {
  PENDING
  ACTIVE
  TERMINATED
}

enum StaffPayType {
  COMMISSION
  SALARY
  BOTH
}

enum ProviderType {
  SALON
  STYLIST_INDEPENDENT
  STYLIST_AT_SALON
}

enum BookedVia {
  SALONS_TAB
  STYLISTS_TAB
  PUBLIC_PAGE
}

enum ServiceType {
  IN_SALON
  HOME_SERVICE
}

enum PaymentMethod {
  CASH
  CARD
  UPI
}

enum BookingStatus {
  PENDING
  PENDING_RESCHEDULE
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReviewTargetType {
  STYLIST
  SALON
  BOTH
}
